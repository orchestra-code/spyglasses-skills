# Spyglasses MCP connector configuration (used by .mcp.json).
# Copy to .env and fill in. Do NOT commit real values.
#
# The connector authenticates via OAuth (browser sign-in) — there is no API key
# to configure. The only variable is the endpoint override for local/dev work.

# Override the MCP endpoint for local/dev testing. Defaults to the production
# endpoint (https://www.spyglasses.io/api/mcp) when unset. Must be a publicly
# reachable HTTPS URL so the OAuth redirect can reach it (e.g. an ngrok tunnel).
# e.g. SPYGLASSES_MCP_URL=https://<your-dev-host>/api/mcp
SPYGLASSES_MCP_URL=
